# Execute from RAM (loaded by debugger / SBL over XDS110), not XIP
CONFIG_XIP=n

# Pin control (IOMUX pad config; pulls in PINCTRL_TI_AM263X)
CONFIG_PINCTRL=y

# Serial / console
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Cortex-R5F memory protection
CONFIG_ARM_MPU=y

# GPIO (USER LEDs LD6/LD7 via ti,davinci-gpio + DT pinctrl)
CONFIG_GPIO=y
