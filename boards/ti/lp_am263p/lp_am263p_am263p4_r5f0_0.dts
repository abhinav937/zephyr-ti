/dts-v1/;

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <ti/am263p4_r5f0_0.dtsi>

/ {
	model = "TI LP-AM263P LaunchPad (R5FSS0 Core0)";
	compatible = "ti,lp-am263p-r5f-cluster-0-core-0";

	chosen {
		zephyr,sram = &sram;
		zephyr,sram1 = &atcm;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
	};
};

/*
 * UART0 -> XDS110 USB-UART bridge on the LaunchPad.
 *
 * NOTE: no pinctrl yet. The AM263x IOMUX needs a dedicated pinctrl driver
 * (future work). For first boot we rely on the boot ROM / SBL having already
 * muxed the UART0 console pins, which is the default on the LP-AM263P in UART
 * boot mode. If no output appears, pin mux is the first thing to check.
 */
&uart0 {
	status = "okay";
	current-speed = <115200>;
};

/* RTI0 — Zephyr system tick source. */
&rti0 {
	status = "okay";
};
