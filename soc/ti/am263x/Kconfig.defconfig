if SOC_SERIES_AM263X

config KERNEL_ENTRY
	default "_vector_table" if SOC_SERIES_AM263X_R5

config NUM_IRQS
	# AM263x VIM. Matches the value used by the other TI R5F (am64x) ports;
	# refine against the AM263Px TRM (SPRUJ55) VIM interrupt map if needed.
	default 256 if SOC_SERIES_AM263X_R5

config SYS_CLOCK_HW_CYCLES_PER_SEC
	# RTI counter (FRC0) input clock (FCLK) = 100 MHz on the TMDSCNCD263P ControlCARD.
	# Measured directly (wall-clock stopwatch vs k_uptime_get()): the FRC runs at
	# half the 200 MHz the GEL and TRM describe for the documented path.
	#
	# GEL (C:\ti\...\AM263Px_PLL\AM263Px_Periheral_Clocks.gel:Program_RTI0_Clocks):
	#   MSS_RCM_RTI0_CLK_SRC_SEL = 0x222; _DIV_VAL = 0x000; prints "RTI0 Clock Enabled (200MHz)".
	#   Top-level GEL forces 400 MHz R5 / 200 MHz SYS_CLK (TOP_RCM 0x222 + DIVBY2 0x111).
	# TRM SPRUJ55 §6.4.8.2.1: 0x222 "selects SYS_CLK" for RTI FCLK (labeled FREQ=200 MHz),
	#   DIV=0x000; Table 4-56 shows FCLK (to counters) selectable from SYS_CLK 200 MHz
	#   (vs separate ICLK 200 MHz and other sources like XTAL 25 MHz / EXT_REFCLK 100 MHz).
	# Our soc.c:am263p_enable_rti_clock() does the identical writes (for GEL-less boots).
	# Result: the documented 200 MHz path is active, but effective FCLK to FRC0 is 100 MHz
	# on this board (SYS_CLK tap seen by MSS_RCM RTI mux or downstream FCLK path is half).
	# 100 MHz value is required for wall time; see CLAUDE.md "Verified clock / RTI facts"
	# and ROADMAP.md 2026-06-02 changelog entry for full citations + measurement data.
	default 100000000 if SOC_SERIES_AM263X_R5

if SERIAL

config UART_NS16550
	default y

config UART_NS16550_TI_K3
	default y if SOC_SERIES_AM263X_R5

choice UART_NS16550_VARIANT
	default UART_NS16550_VARIANT_NS16750
endchoice

endif # SERIAL

config BUILD_OUTPUT_BIN
	default n if SOC_SERIES_AM263X_R5

endif # SOC_SERIES_AM263X
