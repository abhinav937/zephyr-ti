config SOC_SERIES_AM263X_R5
	select ARM
	select CPU_CORTEX_R5
	select CPU_HAS_ARM_MPU
	select VFP_SP_D16
	select ARM_CUSTOM_INTERRUPT_CONTROLLER
	select TI_VIM
	select UART_NS16550_ACCESS_WORD_ONLY if UART_NS16550
	select SOC_EARLY_INIT_HOOK

if SOC_FAMILY_TI_AM263X

config SOC_PART_NUMBER
	default "AM263P4" if SOC_AM263P4

endif # SOC_FAMILY_TI_AM263X
